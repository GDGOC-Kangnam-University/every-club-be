# GCP Configuration
export PROJECT_ID=your-project-id
export REGION=us-west1
export VM_NAME=every-club-db
export REPO=your-org/your-repo

# Database
export DB_HOST=your-vm-ip
export DB_USER=everyclub
export DB_PASS=changeme
export DB_NAME=every-club

# Auth
export JWT_SECRET=your-very-long-hex-secret

# SMTP
export SMTP_HOST="your-smtp-host"
export SMTP_PORT=587
export SMTP_USERNAME="your-smtp-user"
export SMTP_PASSWORD="your-smtp-password"

# S3 / Cloud Storage
export S3_ENDPOINT="https://storage.googleapis.com"
export S3_ACCESS_KEY="your-access-key"
export S3_SECRET_KEY="your-secret-key"
export S3_BUCKET=your-bucket-name
